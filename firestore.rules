rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGameCreator(gameId) {
      return isAuthenticated()
          && get(/databases/$(database)/documents/games_v2/$(gameId)).data.creatorUserId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated()
          && exists(/databases/$(database)/documents/appUser_v2/$(request.auth.uid))
          && get(/databases/$(database)/documents/appUser_v2/$(request.auth.uid)).data.role == 'admin_user';
    }

    function isActiveEditor(gameId) {
      return isAuthenticated()
          && get(/databases/$(database)/documents/games_v2/$(gameId)).data.activeEditorUserId == request.auth.uid;
    }

    function approvalDocId(gameId) {
      return gameId + '_' + request.auth.uid;
    }

    function hasApprovedViewAccess(gameId) {
      let docPath = /databases/$(database)/documents/gameViewApprovals_v2/$(approvalDocId(gameId));
      return exists(docPath)
          && get(docPath).data.status == 'approved';
    }

    function canManageViewApprovals(gameId) {
      return isAdmin() || isActiveEditor(gameId);
    }

    function gamePinGeneration(gameId) {
      let game = get(/databases/$(database)/documents/games_v2/$(gameId)).data;
      return game.keys().hasAll(['pinGeneration']) ? game.pinGeneration : 1;
    }

    function validEditGeneration(gameId) {
      return request.resource.data.keys().hasAll(['editGeneration'])
          && request.resource.data.editGeneration == gamePinGeneration(gameId);
    }

    function isAdminGameEconomicsUpdate() {
      return isAdmin()
          && resource.data.keys().hasAll(['data'])
          && request.resource.data.keys().hasAll(['data'])
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['data', 'lastUpdated', 'editGeneration', 'version'])
          && request.resource.data.data.diff(resource.data.data).affectedKeys()
              .hasOnly(['pointValue', 'gstPercent']);
    }

    function canCreateGameData(gameId) {
      return (isGameCreator(gameId) || isActiveEditor(gameId) || isAdmin())
          && (!request.resource.data.keys().hasAll(['editGeneration'])
              || request.resource.data.editGeneration == gamePinGeneration(gameId));
    }

    function canUpdateGameData(gameId) {
      return (isActiveEditor(gameId) && validEditGeneration(gameId))
          || isAdminGameEconomicsUpdate();
    }

    match /games_v2/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
          && request.resource.data.creatorUserId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /gameData_v2/{gameId} {
      allow read: if isAuthenticated() && (
        isAdmin()
        || isGameCreator(gameId)
        || isActiveEditor(gameId)
        || hasApprovedViewAccess(gameId)
      );
      allow create: if canCreateGameData(gameId);
      allow update: if isAuthenticated() && canUpdateGameData(gameId);
      allow delete: if isGameCreator(gameId) || isAdmin();
    }

    match /gameViewApprovals_v2/{approvalId} {
      allow read: if isAuthenticated() && (
        !exists(/databases/$(database)/documents/gameViewApprovals_v2/$(approvalId))
        || resource.data.userId == request.auth.uid
        || canManageViewApprovals(resource.data.gameId)
      );
      allow create: if isAuthenticated()
          && approvalId == request.resource.data.gameId + '_' + request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && (
            request.resource.data.status == 'requested'
            || (
              request.resource.data.status == 'approved'
              && isGameCreator(request.resource.data.gameId)
            )
          );
      allow update: if isAuthenticated()
          && canManageViewApprovals(resource.data.gameId);
      allow delete: if isAuthenticated();
    }

    match /approvedGames_v2/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /appUser_v2/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /gameDefaults_v2/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /approvedGamesReport_v2/{monthDoc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
