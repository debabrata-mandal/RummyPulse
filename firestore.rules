rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is creator of the game
    function isGameCreator(gameId) {
      return isAuthenticated()
          && get(/databases/$(database)/documents/games_v2/$(gameId)).data.creatorUserId == request.auth.uid;
    }

    // Games collection (v2 — app uses this)
    match /games_v2/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
          && request.resource.data.creatorUserId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Game data collection (v2)
    match /gameData_v2/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Approved games collection (v2 — reports/review)
    match /approvedGames_v2/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // App users collection (v2)
    match /appUser_v2/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /gameDefaults_v2/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Pre-aggregated reports (v2)
    match /approvedGamesReport_v2/{monthDoc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // --- Legacy v1 collections (archived; app no longer writes here) ---
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
          && request.resource.data.creatorUserId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /gameData/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /approvedGames/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /appUser/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /gameDefaults/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /approvedGamesReport/{monthDoc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
