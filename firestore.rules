rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGameCreator(gameId) {
      return isAuthenticated()
          && get(/databases/$(database)/documents/games_v2/$(gameId)).data.creatorUserId == request.auth.uid;
    }

    function gamePinGeneration(gameId) {
      let game = get(/databases/$(database)/documents/games_v2/$(gameId)).data;
      return game.keys().hasAll(['pinGeneration']) ? game.pinGeneration : 1;
    }

    function validEditGeneration(gameId) {
      return request.resource.data.keys().hasAll(['editGeneration'])
          && request.resource.data.editGeneration == gamePinGeneration(gameId);
    }

    match /games_v2/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
          && request.resource.data.creatorUserId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /gameData_v2/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
          && (!request.resource.data.keys().hasAll(['editGeneration'])
              || request.resource.data.editGeneration == gamePinGeneration(gameId));
      allow update: if isAuthenticated() && validEditGeneration(gameId);
      allow delete: if isAuthenticated();
    }

    match /approvedGames_v2/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /appUser_v2/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /gameDefaults_v2/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /approvedGamesReport_v2/{monthDoc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
