<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_game_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- Compact player row: icon | name | total | delete | drag -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_gamepad"
            android:tint="#2196F3"
            android:background="@drawable/circle_background"
            android:padding="8dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="20dp">

                <EditText
                    android:id="@+id/text_player_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minEms="6"
                    android:maxEms="12"
                    android:text="Player Name"
                    android:hint="Tap to enter name"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:imeOptions="actionDone"
                    android:selectAllOnFocus="true" />

                <ImageView
                    android:id="@+id/btn_delete_player"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_delete"
                    android:background="@drawable/small_delete_button_background"
                    android:padding="3dp"
                    android:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Delete Player"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <TextView
                android:id="@+id/text_player_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#21"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:minWidth="52dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_card_total_label"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/text_player_total_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFC107"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>

        <ImageView
            android:id="@+id/drag_handle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_drag_handle"
            android:tint="@color/text_secondary"
            android:background="?android:attr/selectableItemBackground"
            android:padding="2dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Drag to reorder"
            android:scaleType="fitCenter"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
