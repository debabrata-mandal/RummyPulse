<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/professional_row_background"
        android:padding="20dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/text_view_access_dialog_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳"
            android:textSize="40sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/text_view_access_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/text_view_access_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_view_access_dialog_ok"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/view_access_dialog_ok"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/approve_button_background" />

</LinearLayout>
